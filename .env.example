# ═══════════════════════════════════════════════════════════════
#  HealthNG AI — Environment Variables
#  1. Copy this file:  cp .env.example .env
#  2. Fill in your keys below
#  3. NEVER commit .env to Git — it is already in .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Flask ────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-long-random-secret-key-here
FLASK_ENV=development
PORT=5000

# ── AI Providers (add as many as you want) ───────────────────
# The app tries them in this exact order:
# Groq → Together AI → OpenRouter → Cloudflare → HuggingFace → Gemini
# If one hits quota, it automatically moves to the next.
# You only need ONE key to work — but more = more reliable.

# 1. GROQ — Fastest. Free. 14,400 req/day
#    Get key: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# 2. TOGETHER AI — 100+ models. $1 free credit on signup
#    Get key: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your-together-api-key-here

# 3. OPENROUTER — Routes across 200+ models. 20+ truly free
#    Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# 4. CLOUDFLARE WORKERS AI — 10,000 neurons/day free forever
#    Get from: https://dash.cloudflare.com → Workers & Pages → Overview
#    Then: https://dash.cloudflare.com/profile/api-tokens
CF_ACCOUNT_ID=your-cloudflare-account-id-here
CF_API_TOKEN=your-cloudflare-api-token-here

# 5. HUGGING FACE — Thousands of models. Free rate-limited tier
#    Get key: https://huggingface.co/settings/tokens
HF_API_KEY=your-huggingface-token-here

# 6. GEMINI — Google AI. 1M tokens/day free
#    Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
