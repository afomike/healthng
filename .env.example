# ─────────────────────────────────────────────────────────────
#  HealthNG AI  —  Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────

# Flask secret key — change to a long random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Gemini API key — get a FREE key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Flask environment (development | production)
FLASK_ENV=production

# Port (Render sets this automatically; leave as 5000 for local)
PORT=5000
